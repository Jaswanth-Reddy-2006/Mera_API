# =========================================================================
# Mera API Private AI Gateway Configuration Template (.env.example)
# =========================================================================

# 1. Server Configuration
PORT=5000
NODE_ENV=development

# 2. Reverse Proxy Deployment Trust Configuration
# Set to 'loopback' for local proxy, '127.0.0.1' for Nginx, or 'true' to trust all upstream headers (e.g. AWS ALB)
TRUST_PROXY=loopback

# 3. Security Credentials (Single Personal API Key)
# IMPORTANT: Generate a strong custom key for production usage.
# Command to generate: node -e "console.log('sk_private_gateway_' + require('crypto').randomBytes(32).toString('hex'))"
API_KEY=your_secure_api_key_here

# 4. CORS Setup (Trusted Frontend Domains)
# Comma-separated list of domains. Set to '*' to allow all (only in development) or define trusted hosts.
# Examples: http://localhost:3000,https://my-ui-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://my-private-app.com

# 5. Payload Limits & Size Defenses
# Controls express body parser sizes to mitigate DDoS or out-of-memory crashes.
MAX_PAYLOAD_SIZE=5mb

# 6. Ollama Inference Orchestration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_NUM_CTX=8192

# 7. Network Latency & Model Outage Protections
# Maximum time (in milliseconds) the gateway waits for Ollama to begin returning predictions.
OLLAMA_TIMEOUT_MS=120000

# 8. Logger Diagnostic Configurations
# Toggle verbose logs to print full JSON payloads sent to local Ollama
DEBUG=false
